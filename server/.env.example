PORT=3006
HOST=0.0.0.0
NODE_ENV=development

# Security
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=replace-with-32-plus-char-key

# Frontend URL for CORS (set to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3000

# SQLite defaults (Render production should use /var/data paths)
DB_PATH=../database/pms.db
UPLOADS_DIR=../uploads
# Optional JSON/urlencoded body cap in MB for non-file APIs (0 uses default 50MB)
API_BODY_LIMIT_MB=50
# Optional upload cap in MB for certificate files (0 = no app-level limit)
CERTIFICATE_MAX_FILE_SIZE_MB=0

# Optional public API base URL used in some file URL responses
API_BASE_URL=

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@prinstine.com

# Optional: PostgreSQL (if set, backend attempts PostgreSQL mode)
DATABASE_URL=https://prinstine-group-system.onrender.com
